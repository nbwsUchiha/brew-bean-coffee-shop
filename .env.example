# =============================================================================
# PUBLIC (Vite — embedded in frontend bundle)
# =============================================================================
VITE_API_BASE_URL=http://localhost:8787
VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_SITE_URL=http://localhost:5173

# =============================================================================
# PRIVATE (Cloudflare Worker — wrangler secret put or worker/.dev.vars)
# =============================================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_SUCCESS_URL=http://localhost:5173/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:5173/cancel

# Email (optional — Resend)
RESEND_API_KEY=re_...
RESEND_FROM=Brew & Bean <orders@yourdomain.com>

# Worker configuration
ALLOWED_ORIGINS=http://localhost:5173,https://brew-bean-coffee.pages.dev
STORE_NAME=Brew & Bean Coffee
TAX_RATE_BPS=800
PICKUP_FEE_CENTS=0
DELIVERY_FEE_CENTS=499
ADMIN_SETUP_SECRET=choose-a-long-random-secret

# =============================================================================
# GitHub Actions / Cloudflare deploy
# =============================================================================
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_PAGES_PROJECT_NAME=brew-bean-coffee
